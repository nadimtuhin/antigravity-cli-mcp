{
  "name": "universal-ai-cli-mcp",
  "version": "1.0.3",
  "description": "Universal MCP server — exposes agy, kilo, opencode, codex, and hermes AI CLI tools in a single MCP server",
  "type": "module",
  "bin": {
    "universal-ai-cli-mcp": "dist/index.js"
  },
  "files": [
    "dist/index.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outfile dist/index.js --banner \"#!/usr/bin/env bun\"",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agy",
    "kilo",
    "opencode",
    "codex",
    "hermes",
    "ai",
    "cli"
  ],
  "author": "Nadim Tuhin <nadimtuhin@gmail.com>",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "mcp-cli-core": "workspace:*"
  }
}
