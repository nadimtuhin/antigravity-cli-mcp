# Path to each CLI binary (defaults to searching PATH)
AGY_PATH=agy
KILO_PATH=kilo
OPENCODE_PATH=opencode
CODEX_PATH=codex
HERMES_PATH=hermes

# Timeout in milliseconds (default: 300000 = 5 minutes)
AGY_TIMEOUT_MS=300000
KILO_TIMEOUT_MS=300000
OPENCODE_TIMEOUT_MS=300000
CODEX_TIMEOUT_MS=300000
HERMES_TIMEOUT_MS=300000

# Workspace root for file write operations (default: cwd)
AGY_WORKSPACE_ROOT=/path/to/your/workspace
KILO_WORKSPACE_ROOT=/path/to/your/workspace
OPENCODE_WORKSPACE_ROOT=/path/to/your/workspace
CODEX_WORKSPACE_ROOT=/path/to/your/workspace
HERMES_WORKSPACE_ROOT=/path/to/your/workspace

# Max concurrent CLI processes (default: 3)
AGY_MAX_CONCURRENT=3
